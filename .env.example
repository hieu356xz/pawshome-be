DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=pawshome

PORT=3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# AWS S3 Configuration (or S3-compatible provider like DigitalOcean Spaces, MinIO)
AWS_REGION=us-east-1
AWS_ENDPOINT=  # Optional: for S3-compatible providers (e.g., https://nyc3.digitaloceanspaces.com)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_BUCKET_NAME=your-bucket-name
AWS_BUCKET_PUBLIC_URL=https://your-bucket.s3.amazonaws.com

# Gemini Embedding API
GEMINI_API_KEY=your-gemini-api-key

# Environment
NODE_ENV=development
